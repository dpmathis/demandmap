generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Shared Reference Data (read-only, pre-loaded) ─────────────────────────

model CensusBlock {
  geoid       String @id
  stateFips   String @map("state_fips")
  countyFips  String @map("county_fips")
  tract       String
  block       String
  borough     String?
  ntaCode     String? @map("nta_code")
  ntaName     String? @map("nta_name")
  landAreaSqm Float? @map("land_area_sqm")

  totalJobs         Int? @map("total_jobs")
  cns07Retail       Int? @map("cns07_retail")
  cns09Information  Int? @map("cns09_information")
  cns10Finance      Int? @map("cns10_finance")
  cns11RealEstate   Int? @map("cns11_real_estate")
  cns12Professional Int? @map("cns12_professional")
  cns13Management   Int? @map("cns13_management")
  cns14Admin        Int? @map("cns14_administrative")

  primaryLandUse      String? @map("primary_land_use")
  totalOfficeSqft     Float?  @map("total_office_sqft")
  totalCommercialSqft Float?  @map("total_commercial_sqft")
  totalResUnits       Int?    @map("total_residential_units")

  nearestSubwayMeters Float?  @map("nearest_subway_meters")
  subwayLines         String? @map("subway_lines")

  updatedAt DateTime @default(now()) @map("updated_at")

  hourlyDemand     BlockHourlyDemand[]
  opportunityScore OpportunityScore?
  routeStops       RouteStop[]

  @@map("census_blocks")
}

model NtaBoundary {
  ntaCode  String @id @map("nta_code")
  ntaName  String @map("nta_name")
  borough  String

  totalJobs         Int?   @map("total_jobs")
  totalBlocks       Int?   @map("total_blocks")
  avgCompositeScore Float? @map("avg_composite_score")

  @@map("nta_boundaries")
}

model BlockHourlyDemand {
  censusBlockGeoid String @map("census_block_geoid")
  timeWindow       String @map("time_window")
  demandScore      Float  @map("demand_score")
  demandComponents Json?  @map("demand_components")

  censusBlock CensusBlock @relation(fields: [censusBlockGeoid], references: [geoid])

  @@id([censusBlockGeoid, timeWindow])
  @@index([timeWindow])
  @@map("block_hourly_demand")
}

model OpportunityScore {
  censusBlockGeoid      String @id @map("census_block_geoid")
  supplyScore           Float? @map("supply_score")
  demandScore           Float? @map("demand_score")
  gapScore              Float? @map("gap_score")
  compositeScore        Float? @map("composite_score")
  specialtyCount500m    Int?   @map("specialty_count_500m")
  premiumCount500m      Int?   @map("premium_count_500m")
  mainstreamCount500m   Int?   @map("mainstream_count_500m")
  nearestSpecialtyM     Float? @map("nearest_specialty_meters")
  computedAt            DateTime @default(now()) @map("computed_at")

  censusBlock CensusBlock @relation(fields: [censusBlockGeoid], references: [geoid])

  @@map("opportunity_scores")
}

model SubwayStation {
  id               String  @id @default(uuid())
  name             String
  lines            String?
  lat              Float
  lng              Float
  stationComplexId String? @map("station_complex_id")

  @@index([stationComplexId])
  @@map("subway_stations")
}

model StationRidershipBaseline {
  stationComplexId String @map("station_complex_id")
  dayOfWeek        Int    @map("day_of_week")
  hour             Int
  avgRidership     Float  @map("avg_ridership")
  medianRidership  Float? @map("median_ridership")
  sampleWeeks      Int    @default(0) @map("sample_weeks")

  @@id([stationComplexId, dayOfWeek, hour])
  @@index([dayOfWeek, hour])
  @@map("station_ridership_baselines")
}

model CompetitorLocation {
  id               String   @id @default(uuid())
  tenantId         String?  @map("tenant_id")
  name             String
  address          String?
  lat              Float?
  lng              Float?
  censusBlockGeoid String?  @map("census_block_geoid")
  category         String?
  qualityTier      String?  @map("quality_tier")
  qualityScore     Float?   @map("quality_score")
  externalId       String?  @unique @map("external_id")
  source           String?
  sourceGrade      String?  @map("source_grade")
  isChain          Boolean  @default(false) @map("is_chain")
  brandName        String?  @map("brand_name")
  metadata         Json?
  lastVerifiedAt   DateTime? @map("last_verified_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([qualityTier])
  @@map("competitor_locations")
}

// ─── Tenant Data ────────────────────────────────────────────────────────────

model Tenant {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  defaultVertical String   @default("food_truck") @map("default_vertical")
  createdAt       DateTime @default(now()) @map("created_at")

  users       TenantUser[]
  routes      Route[]
  weeklyPlans WeeklyPlan[]
  savedViews  SavedView[]

  @@map("tenants")
}

model TenantUser {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  authId    String   @map("auth_id")
  email     String
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, authId])
  @@index([authId])
  @@map("tenant_users")
}

model Route {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  name       String
  date       DateTime? @db.Date
  vertical   String    @default("food_truck")
  assignedTo String?   @map("assigned_to")
  status     String    @default("draft")
  isTemplate Boolean   @default(false) @map("is_template")
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  stops            RouteStop[]
  weeklyPlanSlots  WeeklyPlanSlot[]

  @@index([tenantId])
  @@map("routes")
}

model RouteStop {
  id               String @id @default(uuid())
  routeId          String @map("route_id")
  censusBlockGeoid String @map("census_block_geoid")
  timeWindow       String @map("time_window")
  sortOrder        Int    @map("sort_order")
  notes            String?
  lat              Float?
  lng              Float?
  createdAt        DateTime @default(now()) @map("created_at")

  route          Route              @relation(fields: [routeId], references: [id], onDelete: Cascade)
  censusBlock    CensusBlock        @relation(fields: [censusBlockGeoid], references: [geoid])
  performanceLogs StopPerformanceLog[]

  @@index([routeId])
  @@map("route_stops")
}

model StopPerformanceLog {
  id          String   @id @default(uuid())
  routeStopId String   @map("route_stop_id")
  date        DateTime @db.Date
  revenue     Float?
  tips        Float?
  unitsSold   Int?     @map("units_sold")
  rating      Int?     // 1-5 self-rating of the stop
  notes       String?
  weather     String?
  createdAt   DateTime @default(now()) @map("created_at")

  routeStop RouteStop @relation(fields: [routeStopId], references: [id], onDelete: Cascade)

  @@index([routeStopId])
  @@index([date])
  @@map("stop_performance_logs")
}

model WeeklyPlan {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  weekStart DateTime @map("week_start") @db.Date
  status    String   @default("draft")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id])
  slots  WeeklyPlanSlot[]

  @@index([tenantId])
  @@map("weekly_plans")
}

model SavedView {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  name      String
  config    Json
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("saved_views")
}

model WeeklyPlanSlot {
  id           String  @id @default(uuid())
  weeklyPlanId String  @map("weekly_plan_id")
  routeId      String  @map("route_id")
  dayOfWeek    Int     @map("day_of_week")
  timeWindow   String  @map("time_window")
  assignedTo   String? @map("assigned_to")
  notes        String?

  weeklyPlan WeeklyPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  route      Route      @relation(fields: [routeId], references: [id])

  @@index([weeklyPlanId])
  @@map("weekly_plan_slots")
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String?  @map("user_id")
  type      String   // weather, closure, demand_spike, system
  title     String
  body      String
  metadata  Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, read])
  @@index([createdAt])
  @@map("notifications")
}

model MapAnnotation {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  userName  String?  @map("user_name")
  lat       Float
  lng       Float
  label     String
  category  String   @default("note") // note, construction, parking, event, hazard
  color     String   @default("#14b8a6")
  notes     String?
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("map_annotations")
}

model ActivityLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  userName  String?  @map("user_name")
  action    String   // created, updated, deleted, cloned, logged_performance
  entity    String   // route, stop, plan, performance
  entityId  String?  @map("entity_id")
  entityName String? @map("entity_name")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("activity_logs")
}

model NotificationPreference {
  id            String  @id @default(uuid())
  tenantId      String  @map("tenant_id")
  userId        String  @map("user_id")
  weatherAlerts Boolean @default(true)  @map("weather_alerts")
  closureAlerts Boolean @default(true)  @map("closure_alerts")
  demandAlerts  Boolean @default(true)  @map("demand_alerts")
  systemAlerts  Boolean @default(true)  @map("system_alerts")

  @@unique([tenantId, userId])
  @@map("notification_preferences")
}
